:root {
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
  color: #f6f8ff;
  background: #05070a;
  --bg-main: #05070a;
  --bg-deep: #020308;
  --glass-bg: rgba(255, 255, 255, 0.075);
  --glass-border: rgba(255, 255, 255, 0.18);
  --line-soft: rgba(255, 255, 255, 0.12);
  --text-main: #f6f8ff;
  --text-muted: rgba(246, 248, 255, 0.66);
  --cyan: #00f5ff;
  --violet: #8b5cf6;
  --pink: #ff7ad9;
  --silver: #d8dee9;
  --warm: #ffd08a;
  --radius-xl: 32px;
  --radius-lg: 22px;
  --shadow-glow: 0 0 44px rgba(0, 245, 255, 0.18);
}
