* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-width: 320px;
  min-height: 100vh;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 18% 12%, rgba(0, 245, 255, 0.16), transparent 30%),
    radial-gradient(circle at 82% 20%, rgba(139, 92, 246, 0.18), transparent 34%),
    radial-gradient(circle at 50% 84%, rgba(255, 122, 217, 0.08), transparent 42%),
    var(--bg-main);
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
  background-size: 54px 54px;
  mask-image: linear-gradient(to bottom, rgba(0,0,0,0.82), rgba(0,0,0,0.14));
  z-index: 0;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input {
  font: inherit;
}

button {
  cursor: pointer;
}

main,
section,
footer,
header {
  position: relative;
  z-index: 1;
}

.city-canvas {
  width: 100% !important;
  height: 100% !important;
}

.top-nav {
  position: fixed;
  left: 50%;
  top: 18px;
  transform: translateX(-50%);
  width: min(1080px, calc(100vw - 32px));
  height: 58px;
  padding: 0 18px;
  border: 1px solid var(--glass-border);
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(4, 7, 13, 0.56);
  backdrop-filter: blur(18px);
  z-index: 20;
}

.brand-mark {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  font-size: 12px;
  letter-spacing: 0.15em;
  color: var(--cyan);
  border: 1px solid rgba(0, 245, 255, 0.4);
  box-shadow: inset 0 0 18px rgba(0, 245, 255, 0.15), 0 0 18px rgba(0, 245, 255, 0.12);
}

.top-nav nav {
  display: flex;
  gap: 22px;
  font-size: 13px;
  color: var(--text-muted);
}

.top-nav a:hover {
  color: var(--text-main);
}

.hero-section {
  min-height: 100vh;
  display: grid;
  place-items: center;
  overflow: hidden;
  padding: 120px 24px 64px;
}

.hero-bg {
  position: absolute;
  inset: 0;
  opacity: 0.96;
}

.scanline {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(to bottom, transparent, rgba(0, 245, 255, 0.12), transparent);
  height: 18vh;
  animation: scan 7s linear infinite;
  opacity: 0.42;
}

@keyframes scan {
  from { transform: translateY(-22vh); }
  to { transform: translateY(110vh); }
}

.hero-content {
  max-width: 920px;
  text-align: center;
  z-index: 2;
}

.eyebrow,
.section-kicker {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  color: var(--cyan);
  letter-spacing: 0.22em;
  font-size: 12px;
  text-transform: uppercase;
}

.eyebrow::before,
.section-kicker::before {
  content: "";
  width: 28px;
  height: 1px;
  background: var(--cyan);
  box-shadow: 0 0 12px var(--cyan);
}

.hero-content h1 {
  margin: 22px 0 4px;
  font-size: clamp(56px, 10vw, 136px);
  line-height: 0.92;
  letter-spacing: -0.08em;
  text-shadow: 0 0 32px rgba(0, 245, 255, 0.18);
}

.hero-subtitle {
  margin: 0;
  font-size: clamp(22px, 4.4vw, 58px);
  color: transparent;
  -webkit-text-stroke: 1px rgba(246, 248, 255, 0.52);
  letter-spacing: 0.03em;
}

.hero-text {
  max-width: 680px;
  margin: 26px auto 34px;
  color: rgba(246, 248, 255, 0.76);
  font-size: 18px;
  line-height: 1.9;
}

.primary-button,
.secondary-button {
  border: 0;
  border-radius: 999px;
  min-height: 48px;
  padding: 0 24px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  letter-spacing: 0.09em;
  font-size: 13px;
  transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}

.primary-button {
  color: #020308;
  background: linear-gradient(135deg, var(--cyan), #ffffff, var(--pink));
  box-shadow: 0 0 28px rgba(0, 245, 255, 0.24);
}

.secondary-button {
  color: var(--text-main);
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.18);
}

.primary-button:hover,
.secondary-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 38px rgba(0, 245, 255, 0.24);
}

.hero-meta {
  position: absolute;
  bottom: 34px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 12px;
  color: rgba(246, 248, 255, 0.5);
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.hero-meta span {
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 999px;
  padding: 8px 12px;
  background: rgba(255, 255, 255, 0.04);
}

.section-shell {
  width: min(1180px, calc(100vw - 36px));
  margin: 0 auto;
  padding: 112px 0;
}

.section-heading {
  max-width: 760px;
  margin-bottom: 42px;
}

.section-heading h2 {
  margin: 16px 0 14px;
  font-size: clamp(32px, 5vw, 64px);
  letter-spacing: -0.06em;
}

.section-heading p {
  color: var(--text-muted);
  font-size: 17px;
  line-height: 1.9;
}

.lab-grid {
  display: grid;
  grid-template-columns: minmax(320px, 0.82fr) minmax(380px, 1.18fr);
  gap: 24px;
  align-items: stretch;
}

.glass-card {
  border: 1px solid var(--glass-border);
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.095), rgba(255, 255, 255, 0.035));
  border-radius: var(--radius-xl);
  backdrop-filter: blur(22px);
  box-shadow: var(--shadow-glow), inset 0 1px 0 rgba(255, 255, 255, 0.13);
}

.control-panel {
  padding: 26px;
}

.control-block {
  padding: 22px 0;
  border-bottom: 1px solid var(--line-soft);
}

.control-block:first-child {
  padding-top: 0;
}

.control-title {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 18px;
  color: var(--text-main);
  font-weight: 600;
}

.control-title span {
  color: var(--cyan);
  font-size: 12px;
  letter-spacing: 0.14em;
}

.density-range {
  width: 100%;
  accent-color: var(--cyan);
}

.value-label {
  margin-top: 10px;
  color: var(--text-muted);
  font-size: 13px;
}

.pill-row,
.flow-grid {
  display: grid;
  gap: 10px;
}

.pill-row {
  grid-template-columns: repeat(3, 1fr);
}

.pill-row button,
.flow-button {
  min-height: 44px;
  border: 1px solid rgba(255, 255, 255, 0.14);
  color: var(--text-muted);
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.045);
  transition: all 0.2s ease;
}

.pill-row button.active,
.flow-button.active {
  color: #051016;
  background: linear-gradient(135deg, var(--cyan), #ffffff);
  border-color: transparent;
}

.flow-grid {
  grid-template-columns: 1fr;
}

.flow-button {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 12px;
  padding: 0 14px;
}

.flow-icon {
  width: 28px;
  height: 16px;
  border-radius: 999px;
  border: 1px solid currentColor;
  position: relative;
}

.flow-icon.linear::after {
  content: "";
  position: absolute;
  left: 5px;
  right: 5px;
  top: 50%;
  height: 1px;
  background: currentColor;
}

.flow-icon.circular {
  border-radius: 50%;
  width: 22px;
  height: 22px;
}

.flow-icon.random::before,
.flow-icon.random::after {
  content: "";
  position: absolute;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: currentColor;
  top: 5px;
}

.flow-icon.random::before { left: 5px; }
.flow-icon.random::after { right: 5px; top: 9px; }

.control-panel .secondary-button {
  width: 100%;
  margin-top: 22px;
}

.preview-card {
  position: relative;
  min-height: 580px;
  overflow: hidden;
}

.preview-topline {
  position: absolute;
  top: 22px;
  left: 22px;
  right: 22px;
  z-index: 2;
  display: flex;
  justify-content: space-between;
  gap: 18px;
  color: var(--text-muted);
  font-size: 12px;
  letter-spacing: 0.12em;
}

.preview-topline strong {
  color: var(--text-main);
}

.preview-canvas-wrap {
  position: absolute;
  inset: 0;
}

.walk-section {
  display: grid;
  grid-template-columns: 0.85fr 1.15fr;
  gap: 38px;
  align-items: start;
}

.sticky-heading {
  position: sticky;
  top: 120px;
}

.narrative-stack {
  display: grid;
  gap: 26px;
}

.narrative-card {
  min-height: 340px;
  padding: 30px;
  overflow: hidden;
  display: grid;
  grid-template-columns: 72px 1fr;
  gap: 20px;
  align-items: start;
  position: relative;
}

.narrative-index {
  color: var(--cyan);
  font-size: 14px;
  letter-spacing: 0.18em;
}

.narrative-en {
  margin: 0 0 10px;
  color: var(--text-muted);
  font-size: 12px;
  letter-spacing: 0.18em;
}

.narrative-card h3 {
  margin: 0 0 14px;
  font-size: clamp(28px, 4vw, 52px);
  letter-spacing: -0.06em;
}

.narrative-card p {
  color: rgba(246, 248, 255, 0.72);
  line-height: 1.9;
}

.narrative-card small {
  color: var(--cyan);
}

.visual-token {
  position: absolute;
  right: 28px;
  bottom: 26px;
  width: 140px;
  height: 140px;
  border-radius: 50%;
  opacity: 0.32;
  filter: blur(0.3px);
}

.visual-token-1 {
  background: conic-gradient(from 120deg, transparent, var(--cyan), white, transparent);
  animation: rotate 12s linear infinite;
}

.visual-token-2 {
  background:
    linear-gradient(90deg, transparent 20%, var(--cyan), transparent 80%),
    linear-gradient(0deg, transparent 20%, var(--violet), transparent 80%);
  border-radius: 22px;
  animation: pulse 4s ease-in-out infinite;
}

.visual-token-3 {
  border: 1px solid var(--cyan);
  box-shadow: 0 0 36px rgba(0, 245, 255, 0.42), inset 0 0 30px rgba(0, 245, 255, 0.16);
}

.visual-token-4 {
  background: radial-gradient(circle, var(--pink), transparent 62%);
  animation: pulse 5s ease-in-out infinite;
}

@keyframes rotate {
  to { transform: rotate(360deg); }
}

@keyframes pulse {
  0%, 100% { transform: scale(0.92); opacity: 0.24; }
  50% { transform: scale(1.08); opacity: 0.44; }
}

.ripple {
  position: absolute;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  border: 1px solid var(--cyan);
  transform: translate(-50%, -50%);
  animation: ripple 1.1s ease-out forwards;
  pointer-events: none;
}

@keyframes ripple {
  to {
    width: 440px;
    height: 440px;
    opacity: 0;
  }
}

.memory-chip {
  display: inline-flex;
  margin-top: 14px;
  color: #05070a;
  background: linear-gradient(135deg, var(--pink), #ffffff);
  border-radius: 999px;
  padding: 10px 14px;
  font-size: 13px;
}

.archive-layout {
  display: grid;
  grid-template-columns: minmax(360px, 0.92fr) minmax(260px, 0.4fr);
  gap: 24px;
  align-items: center;
}

.archive-card {
  padding: 34px;
  min-height: 520px;
  overflow: hidden;
  position: relative;
}

.archive-card::before {
  content: "";
  position: absolute;
  inset: -40%;
  background:
    linear-gradient(90deg, transparent, rgba(0, 245, 255, 0.12), transparent),
    radial-gradient(circle, rgba(139, 92, 246, 0.28), transparent 36%);
  transform: rotate(-14deg);
  pointer-events: none;
}

.card-header,
.card-core,
.metric-grid,
.keyword-row,
.card-description {
  position: relative;
  z-index: 1;
}

.card-header {
  display: flex;
  justify-content: space-between;
  gap: 22px;
  color: var(--text-muted);
  font-size: 12px;
  letter-spacing: 0.16em;
}

.card-header strong {
  color: var(--cyan);
}

.card-core {
  margin: 70px 0 34px;
}

.card-core p {
  margin: 0;
  color: var(--text-muted);
}

.card-core h3 {
  margin: 8px 0 0;
  font-size: clamp(42px, 7vw, 86px);
  line-height: 0.95;
  letter-spacing: -0.08em;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.metric-grid div {
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 18px;
  padding: 16px;
  background: rgba(0, 0, 0, 0.12);
}

.metric-grid span {
  display: block;
  color: var(--text-muted);
  font-size: 12px;
  margin-bottom: 8px;
}

.metric-grid strong {
  font-size: 16px;
}

.keyword-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin: 24px 0;
}

.keyword-row i {
  font-style: normal;
  color: var(--cyan);
  border: 1px solid rgba(0, 245, 255, 0.28);
  border-radius: 999px;
  padding: 8px 12px;
  background: rgba(0, 245, 255, 0.05);
}

.card-description {
  color: rgba(246, 248, 255, 0.74);
  line-height: 1.9;
  font-size: 16px;
}

.archive-actions {
  display: grid;
  gap: 14px;
}

.archive-actions .primary-button,
.archive-actions .secondary-button {
  width: 100%;
}

.ghost-link {
  color: var(--text-muted);
  text-align: center;
  padding: 12px;
}

.site-footer {
  width: min(1180px, calc(100vw - 36px));
  margin: 0 auto;
  padding: 34px 0 54px;
  color: rgba(246, 248, 255, 0.42);
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  display: flex;
  justify-content: space-between;
  gap: 18px;
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

@media (max-width: 920px) {
  .top-nav nav {
    display: none;
  }

  .lab-grid,
  .walk-section,
  .archive-layout {
    grid-template-columns: 1fr;
  }

  .sticky-heading {
    position: relative;
    top: auto;
  }

  .preview-card {
    min-height: 460px;
  }

  .hero-meta {
    flex-wrap: wrap;
    width: calc(100vw - 48px);
    justify-content: center;
  }
}

@media (max-width: 620px) {
  .hero-section {
    padding-inline: 18px;
  }

  .hero-content h1 {
    font-size: clamp(48px, 18vw, 86px);
  }

  .pill-row {
    grid-template-columns: 1fr;
  }

  .narrative-card {
    grid-template-columns: 1fr;
  }

  .metric-grid {
    grid-template-columns: 1fr;
  }

  .site-footer {
    flex-direction: column;
  }
}
